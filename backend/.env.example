# Server
PORT=5000
NODE_ENV=development

# Authentication
# Generate a production value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_secret

# Frontend/CORS
# Use a comma-separated list when you have more than one deployed frontend.
FRONTEND_ORIGIN=http://localhost:3000

# Database
# Leave MONGO_URI blank to use backend/data/db.json for local development.
STORAGE_DRIVER=file
MONGO_URI=
MONGO_DB_NAME=finalproject

# Admin seed
ADMIN_EMAIL=admin@artisanbridge.com
ADMIN_PASSWORD=change_this_before_deploy
ADMIN_NAME=ArtisanBridge Admin

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFY_EMAIL=
